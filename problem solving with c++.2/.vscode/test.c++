#include <iostream>   // Include input-output stream object definitions, also known as iostream or stdio.h file is included by default when we use cout and cin objects from this header files which provide basic operations on inputs and outputs in the program such like printing messages to standard output device etc
using namespace std;  // To avoid prefixing 'std::' with every object name, includes a predefined set of namespaces that contain common types. It also allows you not be prefixed each time by using scope resolution operator "namespace" or simply the keyword from which it inherits them (e.g., iostream)
int main() {          // Every C++ program starts execution at function 'main' 
    cout << "Hello, World!";     // Prints Hello, World! on screen and when compiled & run as a standard output command from cpp compiler with respect to the object code generation. It is done using iostream library in header files for handling streams of characters (like printing texts), also called text IO or simply console based input/output
    return 0;     // returns execution status successfully when program ends its last operation, here it's returning zero indicating successful termination process by the system. The exit() function can be used to terminate a C++ application before executing any statement other than 'return'. When you want your console output no longer appears after compilation & running
}